{
  "name": "solana-todo-app",
  "version": "0.1.0",
  "description": "A decentralized todo application built on Solana with Actions and Blinks",
  "main": "index.js",
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "test": "anchor test --skip-local-validator",
    "build": "anchor build",
    "deploy": "anchor deploy",
    "actions-server": "cd actions-server && npm run dev",
    "frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run actions-server\" \"npm run frontend\""
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "chai": "^4.3.4",
    "concurrently": "^7.6.0",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "typescript": "^4.3.5"
  },
  "workspaces": [
    "actions-server",
    "frontend"
  ]
}
